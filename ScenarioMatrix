scenarioMatrix = [y1x1Obstacle theta1 y2x2Obstacle theta2 y3x3Obstacle theta3 times energy difficultyy];

difficulty = zeros([200 3]);
for i= 1:200
    distance1 = abs(sqrt((y3x3(i, 2) - y1x1(i, 2))^2 + (y3x3(i, 1) - y1x1(i, 1))^2));
    distance2 = abs(sqrt((y3x3(i, 2) - y2x2(i, 2))^2 + (y3x3(i, 1) - y2x2(i, 1))^2));
    if distance2 > distance1
        difficulty(i, 1) = distance1;
    else
        difficulty(i, 1) = distance2;
    end
    difficulty(i, 2) = (distance1+distance2)/2;
    difficulty(i, 3) = distance1;
end

