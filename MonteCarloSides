            xGradientAtCurrentLocationCat2 = gxCat2(floor(pointOnRouteCat2(2)), floor(pointOnRouteCat2(1)));
            yGradientAtCurrentLocationCat2 = gyCat2(floor(pointOnRouteCat2(2)), floor(pointOnRouteCat2(1)));
    
            xNewRouteCat2 = pointOnRouteCat2(1) + speed * xGradientAtCurrentLocationCat2;   
            yNewRouteCat2 = pointOnRouteCat2(2) + speed * yGradientAtCurrentLocationCat2; 
            
            pointOnRouteCat2 = [xNewRouteCat2, yNewRouteCat2];
            
            routeCat2 = [routeCat2; pointOnRouteCat2];
            iterations = iterations - 1;
        end
        
        % cat
        cat2 = bicycleKinematics(MaxSteeringAngle=pi/3, WheelBase=1);
        catGoal2 = routeCat2(end,:);
        catController2 = controllerPurePursuit(Waypoints=routeCat2,DesiredLinearVelocity=speed2,MaxAngularVelocity=2,LookaheadDistance=lookDistance); % m/s, r/s, m

        cycles = 0;
    end
    %% simulating path following
    %% mouse
    [vMouse,omegaMouse] = mouseController(mouseCurrentPose);
    velMouse = derivative(mouse,mouseCurrentPose,[vMouse omegaMouse]);
    mouseCurrentPose = mouseCurrentPose + velMouse*sampleTime;
    mouseDistanceToGoal = norm(mouseCurrentPose(1:2) - mouseGoal(:));

    %% cat1
    [vCat1,omegaCat1] = catController1(catCurrentPose1);
    velCat1 = derivative(cat1,catCurrentPose1,[vCat1 omegaCat1]);
    catCurrentPose1 = catCurrentPose1 + velCat1*sampleTime;
    catDistanceToGoal1 = norm(catCurrentPose1(1:2) - mouseCurrentPose(1:2));

    %% cat2
    [vCat2,omegaCat2] = catController2(catCurrentPose2);
    velCat2 = derivative(cat2,catCurrentPose2,[vCat2 omegaCat2]);
    catCurrentPose2 = catCurrentPose2 + velCat2*sampleTime;
    catDistanceToGoal2 = norm(catCurrentPose2(1:2) - mouseCurrentPose(1:2));


    %% plotting 
    show(map)
    hold on
    
    % path planning plotting

    % mouse
    %quiver(X, Y, gxMouse, gyMouse, 2, 'b'); % quiver plot 
    %quiver(X, Y, VxMouse, VyMouse, 0.8, 'b'); % vortex plot 
    plot(goalMouse(1), goalMouse(2), 'g.', 'MarkerSize', 10); % goal
    %plot(routeMouse(:,1),routeMouse(:,2),"-gs",LineWidth=1,MarkerSize=1,MarkerFaceColor=[0.5 0.5 0.5]);
    %text(mouseCurrentPose(1)+2, mouseCurrentPose(2), 'mouse', Color='g');

    % cat 1
    %quiver(X, Y, gxCat1, gyCat1, 2, 'b'); % quiver plot cat
    %quiver(X, Y, VxCat1, VyCat1, 0.8, 'b');
    %quiver(X, Y, VxCat1Attraction, VyCat1Attraction, 0.8, 'b');
    plot(goalCat1(1), goalCat1(2), 'r.', 'MarkerSize', 30); % goal
    %plot(targetPosition1centre(1), targetPosition1centre(2), '.','MarkerSize', 30, Color='magenta'); % 
    %text(targetPosition1centre(1)+1, targetPosition1centre(2), '1', Color='magenta');
    plot(routeCat1(:,1),routeCat1(:,2),"-gs",LineWidth=1,MarkerSize=1,MarkerFaceColor=[0.5 0.5 0.5]);
    %text(catCurrentPose1(1)+2, catCurrentPose1(2), 'left', Color='r');

    % cat 2
    %quiver(X, Y, gxCat2, gyCat2, 2, 'b'); % quiver plot cat
    %quiver(X, Y, VxCat2, VyCat2, 0.8, 'b');
    %quiver(X, Y, VxCat2Attraction, VyCat2Attraction, 0.8, 'b');
    plot(goalCat2(1), goalCat2(2), 'g.', 'MarkerSize', 30); % goal
    %plot(targetPosition2centre(1), targetPosition2centre(2), '.', 'MarkerSize', 30, Color='cyan');
    %text(targetPosition2centre(1)+1, targetPosition2centre(2), '2', Color='cyan');
    plot(routeCat2(:,1),routeCat2(:,2),"-gs",LineWidth=1,MarkerSize=1,MarkerFaceColor=[0.5 0.5 0.5]);
    %text(catCurrentPose2(1)+2, catCurrentPose2(2), 'right', Color='r');


    % trajectory simulation plotting

    % mouse
    plotTrVecMouse = [mouseCurrentPose(1:2); 0];
    plotRotMouse = axang2quat([0 0 1 mouseCurrentPose(3)]);
    plotTransforms(plotTrVecMouse',plotRotMouse,MeshFilePath="groundvehicle.stl",Parent=gca,View="2D",FrameSize=1.75,MeshColor=[0 0 1]);

    % cat1
    plotTrVecCat1 = [catCurrentPose1(1:2); 0];
    plotRotCat1 = axang2quat([0 0 1 catCurrentPose1(3)]);
    plotTransforms(plotTrVecCat1',plotRotCat1,MeshFilePath="groundvehicle.stl",Parent=gca,View="2D",FrameSize=1.75,MeshColor=[1 0 0]);
    
    % cat2
    plotTrVecCat2 = [catCurrentPose2(1:2); 0];
    plotRotCat2 = axang2quat([0 0 1 catCurrentPose2(3)]);
    plotTransforms(plotTrVecCat2',plotRotCat2,MeshFilePath="groundvehicle.stl",Parent=gca,View="2D",FrameSize=1.75,MeshColor=[1 0 0]);

    hold off
    
    light;
    xlim([23 76])
    ylim([23 76])
    
    cycles = cycles + 1;

    %% observer type thing
    %mouseAllVelocities = [mouseAllVelocities mouseVelocity];
    %catAllVelocities = [catAllVelocities catVelocity];

    it = it + 1;
    % mouse
    mouseAllPoses = [mouseAllPoses mouseCurrentPose];
    mouseVelocity = [(mouseAllPoses(1, it)-mouseAllPoses(1, it-1))/sampleTime;
                     (mouseAllPoses(2, it)-mouseAllPoses(2, it-1))/sampleTime;
                     (mouseAllPoses(3, it)-mouseAllPoses(3, it-1))/sampleTime]; 
    % cat1
    catAllPoses1 = [catAllPoses1 catCurrentPose1];
    catVelocity1 = [(catAllPoses1(1, it)-catAllPoses1(1, it-1))/sampleTime;
                   (catAllPoses1(2, it)-catAllPoses1(2, it-1))/sampleTime;
                   (catAllPoses1(3, it)-catAllPoses1(3, it-1))/sampleTime]; 
    absCatVelocity1 = sqrt((catVelocity1(1)^2)+(catVelocity1(2)^2));

    period1 = predictionDistanceFollower*(catDistanceToGoal1/absCatVelocity1);

    % cat2
    catAllPoses2 = [catAllPoses2 catCurrentPose2];
    catVelocity2 = [(catAllPoses2(1, it)-catAllPoses2(1, it-1))/sampleTime;
                   (catAllPoses2(2, it)-catAllPoses2(2, it-1))/sampleTime;
                   (catAllPoses2(3, it)-catAllPoses2(3, it-1))/sampleTime]; 
    absCatVelocity2 = sqrt((catVelocity2(1)^2)+(catVelocity2(2)^2));

    catVelocities1(velocityCounter, :) = [absCatVelocity1 abs(catVelocity1(3))];
    catVelocities2(velocityCounter, :) = [absCatVelocity2 abs(catVelocity2(3))];
    velocityCounter = velocityCounter + 1;


    period2 = predictionDistanceLeader*(catDistanceToGoal2/absCatVelocity2);


    % predicted target position
    
    % simplest implementation, have one come from left, one from right?
    left = -sideDistance*(catDistanceToGoal1/absCatVelocity1);
    right = sideDistance*(catDistanceToGoal2/absCatVelocity2);
    
    % here I just flipped the names 
    targetPosition1centre = [mouseCurrentPose(1) + (mouseVelocity(1)*period1);
                      mouseCurrentPose(2) + (mouseVelocity(2)*period1)];
    targetPosition2centre = [mouseCurrentPose(1) + (mouseVelocity(1)*period2);
                      mouseCurrentPose(2) + (mouseVelocity(2)*period2)]; 
    targetPosition1 = [mouseCurrentPose(1) + (mouseVelocity(1)*period1) + left;
                      mouseCurrentPose(2) + (mouseVelocity(2)*period1)];
    targetPosition2 = [mouseCurrentPose(1) + (mouseVelocity(1)*period2) + right;
                      mouseCurrentPose(2) + (mouseVelocity(2)*period2)];

    cyclesMouse = cyclesMouse + 1;

    if (catDistanceToGoal1 < catGoalRadius) || (catDistanceToGoal2 < catGoalRadius)
        break
    end
    if (cyclesMouse > 10) || (mouseDistanceToGoal < mouseGoalRadius)
        needNewGoal = 1;
        cyclesMouse = 0;
    end
    %currentTime = currentTime + 0.125;
    waitfor(vizRate);
end
